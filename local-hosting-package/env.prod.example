# Production Environment Configuration Template
# Copy this file to .env.prod and update with your values
# DO NOT commit .env.prod to git!

# Database Configuration
DB_NAME=maharashtra_edu

# Remote MongoDB Connection
MONGO_URL=mongodb://mongo:b5a7adcac8107c867aa1@31.97.207.166:27017/?tls=false

# Frontend Backend URL (API endpoint)
# This should be the backend API URL accessible from the frontend
# If using reverse proxy with /api path: https://school_dashboard.demo.agrayianailabs.com/api
# If using separate subdomain: https://api.school_dashboard.demo.agrayianailabs.com
REACT_APP_BACKEND_URL=https://school_dashboard.demo.agrayianailabs.com/api

# CORS Configuration - Allow production domain
CORS_ORIGINS=https://school_dashboard.demo.agrayianailabs.com,https://school_dashboard.demo.agrayianailabs.com/
CORS_ALLOW_CREDENTIALS=true

# OpenAI Configuration (Optional)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# JWT Configuration - CHANGE THIS TO A STRONG SECRET KEY!
JWT_SECRET_KEY=change-this-to-a-strong-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend Port
FRONTEND_PORT=80

