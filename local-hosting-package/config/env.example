# Database Configuration
DB_NAME=maharashtra_edu

# MongoDB Connection (for docker-compose, use: mongodb://mongodb:27017)
# For external MongoDB, use your connection string
MONGO_URL=mongodb://mongodb:27017

# OpenAI Configuration (Optional - for AI insights)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Frontend Backend URL
# For production, set this to your backend URL (e.g., http://your-domain.com:8002)
# For docker-compose, you can use: http://backend:8002 (internal) or http://localhost:8002 (external)
REACT_APP_BACKEND_URL=http://localhost:8002

